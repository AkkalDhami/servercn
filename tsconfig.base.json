{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "noEmit": true,
    "paths": {
      "@/constants/*": [
        "packages/templates/node/nextjs/component/route-handler/file-api/src/constants/*"
      ],
      "@/utils/*": ["packages/templates/node/nextjs/component/**/src/utils/*"]
    }
  }
}
