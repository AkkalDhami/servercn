{
  "$schema": "https://servercn.vercel.app/schema/component.registry.json",
  "slug": "file-upload",
  "runtimes": {
    "node": {
      "frameworks": {
        "express": {
          "prompt": "Select file upload provider:",
          "variants": {
            "cloudinary": {
              "label": "Cloudinary",
              "dependencies": {
                "runtime": [
                  "express",
                  "pino",
                  "pino-pretty",
                  "dotenv-flow",
                  "cross-env",
                  "multer",
                  "cloudinary",
                  "zod"
                ],
                "dev": ["@types/multer"]
              },
              "env": [
                "CLOUDINARY_CLOUD_NAME",
                "CLOUDINARY_API_KEY",
                "CLOUDINARY_API_SECRET",
                "LOG_LEVEL",
                "PORT"
              ],
              "templates": {
                "mvc": "file-upload/cloudinary/mvc",
                "feature": "file-upload/cloudinary/feature"
              }
            },
            "imagekit": {
              "label": "Imagekit",
              "dependencies": {
                "runtime": [
                  "pino",
                  "pino-pretty",
                  "dotenv-flow",
                  "cross-env",
                  "multer",
                  "@imagekit/nodejs"
                ],
                "dev": ["@types/multer"]
              },
              "env": ["IMAGEKIT_PRIVATE_KEY", "LOG_LEVEL", "PORT"],
              "templates": {
                "mvc": "file-upload/imagekit/mvc",
                "feature": "file-upload/imagekit/feature"
              }
            },
            "aws-s3": {
              "label": "AWS S3",
              "dependencies": {
                "runtime": [
                  "express",
                  "pino",
                  "pino-pretty",
                  "dotenv-flow",
                  "cross-env",
                  "multer",
                  "@aws-sdk/client-s3",
                  "zod"
                ],
                "dev": ["@types/multer"]
              },
              "env": [
                "AWS_REGION",
                "AWS_ACCESS_KEY_ID",
                "AWS_SECRET_ACCESS_KEY",
                "AWS_S3_BUCKET_NAME",
                "LOG_LEVEL",
                "PORT"
              ],
              "templates": {
                "mvc": "file-upload/aws-s3/mvc",
                "feature": "file-upload/aws-s3/feature"
              }
            },
            "cloudflare-r2": {
              "label": "Cloudflare R2",
              "dependencies": {
                "runtime": [
                  "express",
                  "pino",
                  "pino-pretty",
                  "dotenv-flow",
                  "cross-env",
                  "multer",
                  "@aws-sdk/client-s3",
                  "zod"
                ],
                "dev": ["@types/multer"]
              },
              "env": [
                "R2_ACCOUNT_ID",
                "R2_ACCESS_KEY_ID",
                "R2_SECRET_ACCESS_KEY",
                "R2_BUCKET_NAME",
                "R2_PUBLIC_URL",
                "LOG_LEVEL",
                "PORT"
              ],
              "templates": {
                "mvc": "file-upload/cloudflare-r2/mvc",
                "feature": "file-upload/cloudflare-r2/feature"
              }
            }
          }
        }
      }
    }
  }
}
