{
  "$schema": "https://servercn.vercel.app/schema/component.registry.json",
  "slug": "rate-limiter",
  "runtimes": {
    "node": {
      "frameworks": {
        "express": {
          "templates": {
            "mvc": "rate-limiter/mvc",
            "feature": "rate-limiter/feature"
          },
          "dependencies": {
            "runtime": ["express-rate-limit"],
            "dev": [""]
          },
          "env": []
        },
        "nextjs": {
          "prompt": "Select rate limiter strategy:",
          "variants": {
            "custom": {
              "label": "Custom Rate Limiter",
              "templates": {
                "file-api": "rate-limiter/custom/file-api"
              },
              "dependencies": {
                "runtime": [],
                "dev": []
              },
              "env": []
            },
            "upstash": {
              "label": "Upstash Rate Limiter",
              "templates": {
                "file-api": "rate-limiter/upstash/file-api"
              },
              "dependencies": {
                "runtime": ["@upstash/ratelimit", "@upstash/redis"],
                "dev": [""]
              },
              "env": ["UPSTASH_REDIS_REST_TOKEN", "UPSTASH_REDIS_REST_URL"]
            }
          }
        }
      }
    }
  }
}
